# ── TuniHome (second store, optionnel) ───────────────────────────────────────
TUNIHOME_TOKEN=

# ── JAX Delivery — suivi livraison ───────────────────────────────────────────
JAX_API_TOKEN=

# ── Webhook TikTak Space ─────────────────────────────────────────────────────
WEBHOOK_SECRET=change-me-to-a-random-secret

