# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-to-a-random-secret

# ── TikTakPro — catalogue produits ───────────────────────────────────────────
TIKTAKPRO_TOKEN=

# ── TikTak Space — commandes & factures ──────────────────────────────────────
